# Server
PORT=8080
PUBLIC_BASE_URL=readback-production.up.railway.app

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=     # comma-separated Telegram user IDs; reject everyone else
TELEGRAM_WEBHOOK_SECRET=       # random string set when calling setWebhook

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=     # server-only, never expose to web

# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_A=Rachel
ELEVENLABS_VOICE_B=Adam
OPENAI_API_KEY=                # fallback TTS

# YouTube (optional)
YOUTUBE_COOKIES_FILE=          # path to cookies.txt for age-gated videos


# Napkin AI visual generation
NAPKIN_API_KEY=                # from app.napkin.ai → Account Settings → Developers